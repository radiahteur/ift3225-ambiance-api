# Port utilisé par le serveur Express.
PORT=3000

# Exemple de chaîne de connexion MongoDB Atlas.
MONGO_URI=mongodb+srv://<utilisateur>:<motdepasse>@<cluster>.mongodb.net/<nomBaseDonnees>?retryWrites=true&w=majority

# Liste des clés API autorisées.
API_KEYS=key123,key456

# Secret utilisé pour signer les tokens JWT.
JWT_SECRET=<notre_secret_jwt>